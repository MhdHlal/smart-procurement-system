# ----------------------------------------------------------------
# SMART PROCUREMENT SYSTEM (SPS) - ENVIRONMENT TEMPLATE
# ----------------------------------------------------------------
# Instructions:
# 1. Copy this file and rename it to '.env'
# 2. Fill in your actual credentials in the new '.env' file.
# 3. DO NOT commit the actual '.env' file to version control.

# --- Database Configuration ---
# Default for MVP: sqlite:///./procurement.db
# For Production (e.g. PostgreSQL): postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///./procurement.db

# --- SMTP / Email Gateway Settings ---
# Outgoing SMTP server (e.g., smtp.gmail.com)
SMTP_SERVER=smtp.gmail.com

# SMTP Port (e.g., 587 for TLS)
SMTP_PORT=587

# The official email address used to dispatch RFQs
SENDER_EMAIL=your-email@company.com

# Your 16-character App-Specific Password (without spaces)
SENDER_PASSWORD=your-app-password-here

# Optional: Blind Carbon Copy (BCC) for monitoring all outgoing RFQs
BCC_EMAIL=

# --- Application Metadata ---
APP_NAME="Smart Procurement System"
DEBUG_MODE=True

# --- Security (Future Use) ---
# Secret key for session encryption and authentication
SECRET_KEY=generate-a-secure-random-key-here